# PostgreSQL

DB_HOST=localhost
DB_PORT=5432
DB_NAME=credibot
DB_USER=postgres
DB_PASSWORD=

# Twilio
# Account SID empieza con AC... (no uses API Key SK...)
# Auth Token: el token principal de la consola Twilio (Account Info)

TWILIO_ENABLED=true
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_WHATSAPP_NUMBER=
TWILIO_WEBHOOK_URL=

# Groq

GROQ_API_KEY=

# Application

APP_NAME=CrediBot
DEBUG=True