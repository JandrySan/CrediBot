# PostgreSQL
# Si quieres pruebas internas rapidas sin PostgreSQL:
# DATABASE_URL=sqlite:///./credibot.db

DB_HOST=localhost
DB_PORT=5432
DB_NAME=credibot
DB_USER=postgres
DB_PASSWORD=
DATABASE_URL=
SUPABASE_DATABASE_URL=

# Twilio
# Account SID empieza con AC... (no uses API Key SK...)
# Auth Token: el token principal de la consola Twilio (Account Info)

TWILIO_ENABLED=true
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_WHATSAPP_NUMBER=
TWILIO_WEBHOOK_URL=

# Groq

GROQ_API_KEY=

# Audio (speech-to-text)
AUDIO_STT_ENABLED=true
AUDIO_STT_PROVIDER=groq
AUDIO_STT_MODEL=base
AUDIO_STT_LANGUAGE=es
AUDIO_STT_DEVICE=cpu
AUDIO_STT_COMPUTE_TYPE=int8
AUDIO_STT_GROQ_MODEL=whisper-large-v3-turbo
AUDIO_STT_REQUEST_TIMEOUT_SECONDS=20

# Audio reply (bot -> voice note)
AUDIO_REPLY_ENABLED=false
AUDIO_REPLY_LANGUAGE=es
# Opcional: URL publica base (ej: https://xxxx.ngrok-free.app)
# Si esta vacia, se intenta derivar desde TWILIO_WEBHOOK_URL
AUDIO_REPLY_PUBLIC_BASE_URL=

# AI mode
# true: responde por IA en WhatsApp sin ejecutar reglas de negocio
# false: usa el flujo de precalificacion con estados y reglas
AI_ONLY_MODE=false

# Application

APP_NAME=CrediBot
DEBUG=True
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Conversation sessions
# 0 desactiva expiracion automatica.
CONVERSATION_SESSION_TIMEOUT_MINUTES=60
CONVERSATION_CLEANUP_BATCH_SIZE=100
# Dias que se conservan conversaciones cerradas por abandono/expiracion antes de borrarlas.
# 0 desactiva el borrado automatico.
ABANDONED_CONVERSATION_RETENTION_DAYS=7
