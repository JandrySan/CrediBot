# Base de datos (unica variable de conexion)
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/credibot
RUN_DB_MIGRATIONS=true
AUTO_CREATE_DB_SCHEMA=false

# Servicios externos
GROQ_API_KEY=
TWILIO_ENABLED=true
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WEBHOOK_URL=https://TU_DOMINIO/webhook/whatsapp
TWILIO_VALIDATE_SIGNATURE=true

# Acceso al dashboard
DASHBOARD_AUTH_ENABLED=true
DASHBOARD_ADMIN_USERNAME=admin
DASHBOARD_ADMIN_PASSWORD=
DASHBOARD_JWT_SECRET=
# Opcional: segundo usuario con permisos de asesor
DASHBOARD_ADVISOR_USERNAME=
DASHBOARD_ADVISOR_PASSWORD=
DASHBOARD_ACCESS_TOKEN_MINUTES=480

# Aplicacion
DEBUG=false
AI_ONLY_MODE=false
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
WEBHOOK_RATE_LIMIT_PER_MINUTE=120
LOGIN_RATE_LIMIT_PER_MINUTE=10

# Audio: Groq es el proveedor recomendado
AUDIO_STT_ENABLED=true
AUDIO_STT_PROVIDER=groq
AUDIO_STT_GROQ_MODEL=whisper-large-v3-turbo
AUDIO_STT_REQUEST_TIMEOUT_SECONDS=20
AUDIO_REPLY_ENABLED=false

# Solo si AUDIO_STT_PROVIDER usa el modelo local
AUDIO_STT_MODEL=base
AUDIO_STT_DEVICE=cpu
AUDIO_STT_COMPUTE_TYPE=int8

# Sesiones
CONVERSATION_SESSION_TIMEOUT_MINUTES=60
CONVERSATION_CLEANUP_BATCH_SIZE=100
ABANDONED_CONVERSATION_RETENTION_DAYS=7
