{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "InspectCrediBotSecrets",
      "Effect": "Allow",
      "Action": "secretsmanager:DescribeSecret",
      "Resource": "arn:aws:secretsmanager:us-east-1:514090178790:secret:credibot/*"
    },
    {
      "Sid": "ReadDatabaseForMigrations",
      "Effect": "Allow",
      "Action": "secretsmanager:GetSecretValue",
      "Resource": "arn:aws:secretsmanager:us-east-1:514090178790:secret:credibot/database-url-*"
    },
    {
      "Sid": "ManageDashboardSecrets",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:CreateSecret",
        "secretsmanager:PutSecretValue"
      ],
      "Resource": [
        "arn:aws:secretsmanager:us-east-1:514090178790:secret:credibot/dashboard-admin-password-*",
        "arn:aws:secretsmanager:us-east-1:514090178790:secret:credibot/dashboard-jwt-secret-*"
      ]
    },
    {
      "Sid": "RemoveObsoleteWhatsAppSecret",
      "Effect": "Allow",
      "Action": "secretsmanager:DeleteSecret",
      "Resource": [
        "arn:aws:secretsmanager:us-east-1:514090178790:secret:credibot/twilio-webhook-url-*",
        "arn:aws:secretsmanager:us-east-1:514090178790:secret:credibot/twilio-whatsapp-from-*",
        "arn:aws:secretsmanager:us-east-1:514090178790:secret:credibot/twilio-whatsapp-number-*"
      ]
    }
  ]
}
